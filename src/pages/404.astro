---
import Base from "../layouts/Base.astro";
---

<Base title="404: page not found | AgenticSuite" description="This page doesn't exist. Head back to AgenticSuite.">
  <section class="relative overflow-hidden">
    <div class="glow-field" aria-hidden="true"></div>
    <div class="container-site relative flex min-h-[60vh] flex-col items-center justify-center py-24 text-center">
      <p class="chip"><span class="chip-dot" aria-hidden="true"></span>Request denied · no such page</p>
      <h1 class="mt-6 text-6xl font-semibold tracking-tight sm:text-7xl">404</h1>
      <p class="mt-4 max-w-md text-muted">
        Even our agents can't find this one. No approval card will make it exist.
      </p>
      <a href="/" class="btn btn-ink mt-9">Back to AgenticSuite</a>
    </div>
  </section>
</Base>
