---
import Base from "../layouts/Base.astro";
import Badge from "../components/Badge.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ACTDemo from "../components/ACTDemo.astro";
import StatusRail from "../components/StatusRail.astro";
import ProductShot from "../components/ProductShot.astro";
import actApprovalActions from "../assets/product/act-approval-actions.png";
import actApprovalDetail from "../assets/product/act-approval-detail.png";
import actHome from "../assets/product/act-home.png";
import actAgents from "../assets/product/act-agents.png";

const explains = [
  {
    title: "Consequential actions",
    copy: "Submitting a form, rebooting a machine, running a workflow: anything with real-world effect pauses for you.",
  },
  {
    title: "Human approval",
    copy: "Requests arrive as plain-English cards. Approve, modify, or deny in one tap.",
  },
  {
    title: "Signed decisions",
    copy: "Your approval is signed on your device, so the requesting product can verify it really came from you.",
  },
  {
    title: "Clearance consumption",
    copy: "Each clearance is single-use and scoped. It works for the action it was issued for, then it's spent.",
  },
  {
    title: "Audit history",
    copy: "Every request, decision, and action is recorded, so you can always see what happened and why.",
  },
];
---

<Base
  title="ACT: approve what matters from your phone | AgenticSuite"
  description="ACT is AgenticSuite's approval layer. When an agent wants to do something big, the request lands on your phone. Approve, modify, or deny, with a full audit trail."
>
  <section class="relative overflow-hidden">
    <div class="glow-field" aria-hidden="true"></div>
    <div class="container-site relative grid items-center gap-12 pt-16 pb-14 sm:pt-24 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,1fr)]">
      <div>
        <Badge label="ACT · The approval layer · Public beta" tone="beta" />
        <h1 class="mt-6 text-4xl leading-[1.06] font-semibold tracking-tight text-balance sm:text-[3.4rem]">
          Approve what matters from your phone.
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-muted">
          ACT turns risky agent actions into clear approval requests. When an agent wants to do something big, like
          submitting a form or rebooting a server, the request lands on your phone first. You approve, modify, or
          deny. Then, and only then, the action runs.
        </p>
        <div class="mt-8 flex flex-wrap gap-3.5">
          <a href="/#demo-act" class="btn btn-primary">Watch it work</a>
          <a href="https://github.com/MahdiHedhli/AgenticControlTower" class="btn btn-ghost">View on GitHub</a>
        </div>
      </div>
      <ProductShot
        src={actApprovalActions}
        alt="The ACT iOS app showing an approval request: a shell command with operator constraints (read-only first, ask again before writing, only this repo) and Approve and Deny buttons"
        caption="Actual app · demo workspace"
        width={330}
        class="mx-auto"
      />
    </div>
  </section>

  <section class="border-y border-hairline bg-surface">
    <div class="container-site py-16 sm:py-24">
      <SectionHeader
        eyebrow="The flow"
        title="From request to recorded action."
        sub="A request comes in and you review it. If you approve, a signed clearance is issued. The action uses it once, and everything is recorded."
        align="center"
      />
      <StatusRail class="mt-10" />
      <div class="mt-14">
        <ACTDemo />
      </div>
    </div>
  </section>

  <section class="border-b border-hairline">
    <div class="container-site py-16 sm:py-24">
      <SectionHeader
        eyebrow="The real app"
        title="This is ACT, not a concept render."
        sub="Screenshots from the ACT app running with a demo workspace: the tower dashboard, an approval with its redacted payload, and the agent fleet."
        align="center"
      />
      <div class="mt-12 grid items-start justify-items-center gap-10 sm:grid-cols-3">
        <ProductShot
          src={actHome}
          alt="ACT home screen: counts for agents, missions, approvals, notifications and security items, plus a pending high-risk approval card"
          width={300}
          caption="The tower at a glance"
        />
        <ProductShot
          src={actApprovalDetail}
          alt="ACT approval detail: request summary showing state, tool, agent, node, session and expiry, with a redacted payload"
          width={300}
          caption="Every request, in plain terms"
        />
        <ProductShot
          src={actAgents}
          alt="ACT agents screen: a fleet list with per-agent status chips such as running, online, and blocked"
          width={300}
          caption="Your fleet, live states included"
        />
      </div>
    </div>
  </section>

  <section>
    <div class="container-site py-16 sm:py-24">
      <SectionHeader eyebrow="Under the hood" title="Simple on the surface. Strict underneath." />
      <dl class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          explains.map(({ title, copy }) => (
            <div class="card p-6">
              <dt class="font-semibold tracking-tight">{title}</dt>
              <dd class="mt-1.5 text-sm leading-relaxed text-muted">{copy}</dd>
            </div>
          ))
        }
        <div class="card flex flex-col justify-between border-beacon/40 bg-beacon/8 p-6">
          <dt class="font-semibold tracking-tight">Your approval device</dt>
          <dd class="mt-1.5 text-sm leading-relaxed text-muted">
            ACT runs on iOS and Android. Approvals are signed on your phone, backed by its secure hardware.
            <a
              href="https://github.com/MahdiHedhli/AgenticControlTower"
              class="mt-4 block text-sm font-semibold text-ember underline-offset-4 hover:underline"
              >Get started on GitHub →</a
            >
          </dd>
        </div>
      </dl>
    </div>
  </section>
</Base>
