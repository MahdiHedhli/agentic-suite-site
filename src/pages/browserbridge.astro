---
import Base from "../layouts/Base.astro";
import Badge from "../components/Badge.astro";
import SectionHeader from "../components/SectionHeader.astro";
import BrowserBridgeDemo from "../components/BrowserBridgeDemo.astro";
import DemoTimeline from "../components/DemoTimeline.astro";
import ProductShot from "../components/ProductShot.astro";
import bbApproval from "../assets/product/bb-approval-pending-high-risk.png";
import bbPanic from "../assets/product/bb-panic.png";
import bbReady from "../assets/product/bb-ready-idle.png";

const useCases = [
  "Booking and scheduling",
  "Research and comparison",
  "Data entry",
  "Forms and applications",
  "Account workflows",
  "Admin panels",
  "Internal tools",
  "Repetitive web tasks",
];
---

<Base
  title="BrowserBridge: let AI use your browser, safely | AgenticSuite"
  description="BrowserBridge lets AI search, click, and fill out web forms in your real browser. It pauses for your approval in ACT before anything sensitive, like submitting."
>
  <section class="relative overflow-hidden">
    <div class="glow-field" aria-hidden="true"></div>
    <div class="container-site relative pt-16 pb-14 sm:pt-24">
      <div class="mx-auto max-w-3xl text-center">
        <Badge label="BrowserBridge · The browser operator · Public beta" tone="beta" />
        <h1 class="mt-6 text-4xl leading-[1.06] font-semibold tracking-tight text-balance sm:text-[3.4rem]">
          Let AI use your browser, safely.
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-muted">
          BrowserBridge puts AI to work in your real browser, in your real session. It can search, click, compare, and
          fill out the form. You approve the submission.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3.5">
          <a href="#demo" class="btn btn-primary">Watch it work</a>
          <a href="/act" class="btn btn-ghost">See how approval works</a>
        </div>
      </div>
      <div id="demo" class="mx-auto mt-14 max-w-4xl">
        <BrowserBridgeDemo />
      </div>
    </div>
  </section>

  <section class="border-t border-hairline bg-surface">
    <div class="container-site py-16 sm:py-24">
      <SectionHeader
        eyebrow="The real product"
        title="The Control Tower popup, up close."
        sub="Three of the extension's actual screens: a high-risk approval, panic mode, and first-run setup."
        align="center"
      />
      <div class="mt-12 grid items-start justify-items-center gap-8 lg:grid-cols-3">
        <ProductShot
          kind="panel"
          src={bbApproval}
          alt="BrowserBridge Control Tower popup showing a pending high-risk approval: the action, requesting runtime, origins, risk level, why approval is required, and a one-time decision notice"
          width={420}
          caption="A high-risk action, paused"
        />
        <ProductShot
          kind="panel"
          src={bbPanic}
          alt="BrowserBridge panic mode: actions are blocked fail-closed, the target lease is revoked, and a recovery checklist walks the operator back to a safe state"
          width={420}
          caption="Panic mode: everything stops until you recover it"
        />
        <ProductShot
          kind="panel"
          src={bbReady}
          alt="BrowserBridge first-run state: helper health is green and the operator is prompted to set a target tab before any governed browser action"
          width={420}
          caption="Setup: the agent only gets the tab you point it at"
        />
      </div>
    </div>
  </section>

  <section class="border-y border-hairline">
    <div class="container-site grid gap-12 py-16 sm:py-24 lg:grid-cols-2">
      <div>
        <SectionHeader
          eyebrow="How it feels"
          title="Hand AI the annoying website task."
          sub="A Chrome extension plus a local companion. The agent works in the browser you already use. No handing over passwords, no shipping your session to a bot farm in the cloud."
        />
        <DemoTimeline
          class="mt-8"
          approvalIndex={3}
          steps={[
            "The agent opens the site and works through it like you would",
            "It searches, compares options, and fills the safe fields",
            "Anything big, like submit, purchase, or delete, pauses",
            "You approve from your phone",
            "The task finishes, and the whole run is recorded",
          ]}
        />
      </div>
      <div>
        <SectionHeader eyebrow="Where it shines" title="Made for the web's busywork." />
        <ul class="mt-8 grid grid-cols-2 gap-3">
          {
            useCases.map((u) => (
              <li class="card px-4 py-3.5 text-[0.9rem] font-medium">{u}</li>
            ))
          }
        </ul>
        <p class="mt-6 text-sm leading-relaxed text-muted">
          Sensitive actions need a signed, single-use approval. A big step can't run without a clearance you issued, and
          a panic button revokes in-flight authority where supported.
        </p>
      </div>
    </div>
  </section>

  <section>
    <div class="container-site flex flex-wrap items-center justify-between gap-6 py-16 sm:py-20">
      <p class="max-w-lg text-lg font-medium text-balance">
        AI can fill the form. <span class="text-ember">You approve the submission.</span>
      </p>
      <a href="https://github.com/MahdiHedhli" class="btn btn-ink">AgenticSuite on GitHub</a>
    </div>
  </section>
</Base>
