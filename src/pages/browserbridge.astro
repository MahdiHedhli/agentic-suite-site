---
import Base from "../layouts/Base.astro";
import Badge from "../components/Badge.astro";
import SectionHeading from "../components/SectionHeading.astro";

const safety = [
  "Consequential actions are gated through signed clearances.",
  "A panic control instantly revokes in-flight authority.",
  "The agent can't act on anything you haven't cleared.",
];
---

<Base
  title="BrowserBridge — secure AI co-browsing | Agentic Control Suite"
  description="BrowserBridge lets an AI agent browse, click, fill forms, and submit in your real browser while routing every consequential action through the control tower for approval."
>
  <section class="relative overflow-hidden border-b border-hairline">
    <div class="grid-backdrop absolute inset-0" aria-hidden="true"></div>
    <div class="container-site relative py-20 sm:py-28">
      <p class="kicker">// ACS-BRB · Co-browsing</p>
      <div class="mt-4 flex flex-wrap items-center gap-4">
        <h1 class="text-4xl font-semibold tracking-tight text-balance sm:text-5xl">BrowserBridge</h1>
        <Badge label="Beta · Coming to the Chrome Web Store" />
      </div>
      <p class="mt-6 text-xl text-beacon sm:text-2xl">Secure AI co-browsing. The agent drives; you clear the turns.</p>
      <p class="mt-6 max-w-2xl text-base leading-relaxed text-muted sm:text-lg">
        BrowserBridge lets an AI agent browse, click, fill forms, and submit in a real browser — yours — while routing
        every consequential action through the control tower for approval. It's a Chrome extension plus a local
        companion, so the agent works in your actual session without you handing over the keys.
      </p>
    </div>
  </section>

  <section class="border-b border-hairline">
    <div class="container-site py-20 sm:py-24">
      <SectionHeading kicker="// Fail-closed" title="How it stays safe" />
      <ul class="mt-10 grid max-w-4xl gap-4 sm:grid-cols-3" role="list">
        {
          safety.map((item) => (
            <li class="hairline-card flex gap-4 p-5 text-sm leading-relaxed text-ink">
              <span class="mt-1.5 h-2 w-2 flex-none bg-beacon" aria-hidden="true" />
              {item}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section>
    <div class="container-site py-20 sm:py-24">
      <div class="hairline-card flex flex-col items-start gap-6 p-8 sm:p-10">
        <p class="kicker">// Holding pattern</p>
        <p class="max-w-xl text-lg text-ink">
          BrowserBridge is in beta and headed for the Chrome Web Store. The launch will be announced on GitHub.
        </p>
        <a
          href="https://github.com/MahdiHedhli"
          class="btn btn-primary"
          title="Follow MahdiHedhli on GitHub — the Chrome Web Store launch will be announced there"
        >
          Notify me when it's on the Chrome Web Store
        </a>
        <p class="font-mono text-[0.7rem] tracking-[0.12em] uppercase text-muted">
          Announced via GitHub · No signup · No backend
        </p>
      </div>
    </div>
  </section>
</Base>
