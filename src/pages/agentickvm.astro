---
import Base from "../layouts/Base.astro";
import Badge from "../components/Badge.astro";
import SectionHeading from "../components/SectionHeading.astro";

const useCases = [
  "Recover a machine that's stopped responding, without a truck roll.",
  "Datacenter and homelab operations.",
  "Out-of-band diagnostics.",
];

const safety = [
  "Every mutating action (power, boot) requires an operator-approved, signed clearance.",
  "Read-only observation is separated from control.",
  "Transport is certificate-pinned.",
  "Fail-closed on any gap.",
];
---

<Base
  title="AgenticKVM — out-of-band infrastructure control for AI agents | Agentic Control Suite"
  description="AgenticKVM lets an AI agent operate machines at the hardware level — power, boot, console — over Redfish, IPMI, and PiKVM, but only through signed clearances from the control tower."
>
  <section class="relative overflow-hidden border-b border-hairline">
    <div class="grid-backdrop absolute inset-0" aria-hidden="true"></div>
    <div class="container-site relative py-20 sm:py-28">
      <p class="kicker">// ACS-KVM · Out-of-band</p>
      <div class="mt-4 flex flex-wrap items-center gap-4">
        <h1 class="text-4xl font-semibold tracking-tight text-balance sm:text-5xl">AgenticKVM</h1>
        <Badge label="Open source · Beta" />
      </div>
      <p class="mt-6 text-xl text-beacon sm:text-2xl">Out-of-band infrastructure control for AI agents — safely.</p>
      <p class="mt-6 max-w-2xl text-base leading-relaxed text-muted sm:text-lg">
        AgenticKVM lets an AI agent operate machines at the hardware level — power, boot, console — the way a human
        operator would through a KVM or BMC. It speaks Redfish, IPMI, and PiKVM, so an agent can recover a wedged
        server, change a boot device, or observe a console — but only through a signed clearance from the control
        tower.
      </p>
    </div>
  </section>

  <section class="border-b border-hairline">
    <div class="container-site py-20 sm:py-24">
      <SectionHeading kicker="// Use cases" title="What it's for" />
      <ul class="mt-10 max-w-2xl space-y-4" role="list">
        {
          useCases.map((item) => (
            <li class="flex gap-4 text-base leading-relaxed text-ink">
              <span class="mt-2 h-2 w-2 flex-none bg-beacon" aria-hidden="true" />
              {item}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="border-b border-hairline">
    <div class="container-site py-20 sm:py-24">
      <SectionHeading kicker="// Fail-closed" title="How it stays safe" />
      <ul class="mt-10 grid max-w-4xl gap-4 sm:grid-cols-2" role="list">
        {
          safety.map((item) => (
            <li class="hairline-card flex gap-4 p-5 text-sm leading-relaxed text-ink">
              <span class="mt-1.5 h-2 w-2 flex-none bg-beacon" aria-hidden="true" />
              {item}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section>
    <div class="container-site flex flex-wrap items-center justify-between gap-6 py-20 sm:py-24">
      <p class="max-w-md text-base leading-relaxed text-muted">
        The protocol, the clearance flow, and the transports are open for inspection.
      </p>
      <a href="https://github.com/MahdiHedhli/AgenticKVM" class="btn btn-secondary">View AgenticKVM on GitHub</a>
    </div>
  </section>
</Base>
