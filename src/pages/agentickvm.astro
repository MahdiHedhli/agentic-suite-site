---
import Base from "../layouts/Base.astro";
import Badge from "../components/Badge.astro";
import SectionHeader from "../components/SectionHeader.astro";
import AgenticKVMDemo from "../components/AgenticKVMDemo.astro";
import DemoTimeline from "../components/DemoTimeline.astro";
import ProductShot from "../components/ProductShot.astro";
import actApprovalDetail from "../assets/product/act-approval-detail.png";

const useCases = [
  "Homelab recovery",
  "VM host troubleshooting",
  "Server console operations",
  "Boot recovery",
  "Network lockout recovery",
  "Remote machine triage",
  "Out-of-band visibility",
  "Controlled infrastructure ops",
];
---

<Base
  title="AgenticKVM: fix servers you can't reach | AgenticSuite"
  description="AgenticKVM lets AI agents see and operate machines through PiKVM, BMC, and VM host consoles when SSH is down. Risky actions wait for your approval in ACT."
>
  <section class="band-night relative overflow-hidden">
    <div class="container-site relative pt-16 pb-16 sm:pt-24">
      <div class="mx-auto max-w-3xl text-center">
        <Badge label="AgenticKVM · The out-of-band operator · Public beta" tone="beta" dark />
        <h1 class="mt-6 text-4xl leading-[1.06] font-semibold tracking-tight text-balance text-night-ink sm:text-[3.4rem]">
          Fix servers you can't reach.
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-night-muted">
          Most AI agents give up when SSH is down. AgenticKVM can still see the screen and press the keys, through the
          same console you would use. Anything risky waits for your OK.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3.5">
          <a href="#demo" class="btn btn-primary">Watch a recovery</a>
          <a href="https://github.com/MahdiHedhli/AgenticKVM" class="btn border-night-hairline text-night-ink hover:border-night-muted">
            View on GitHub
          </a>
        </div>
      </div>
      <div id="demo" class="mx-auto mt-14 max-w-5xl">
        <AgenticKVMDemo />
      </div>
    </div>
  </section>

  <section class="border-b border-hairline bg-surface">
    <div class="container-site grid gap-12 py-16 sm:py-24 lg:grid-cols-2">
      <div>
        <SectionHeader
          eyebrow="From prompt to console"
          title="Eyes and hands at the console."
          sub="When a machine stops answering, AgenticKVM goes in through the back door: PiKVM devices, BMC consoles, and VM host consoles. It speaks standards like Redfish and IPMI, and it works with gear you already own."
        />
        <DemoTimeline
          class="mt-8"
          approvalIndex={3}
          steps={[
            "Ping fails, SSH fails. The normal ways in are gone",
            "The agent opens the machine's console, watch-only",
            "It reads the screen and works out what broke",
            "You approve the fix from your phone",
            "It presses the keys and the machine comes back",
            "You get a written record of everything it did",
          ]}
        />
      </div>
      <div>
        <SectionHeader eyebrow="Where it shines" title="For the day something breaks." />
        <ul class="mt-8 grid grid-cols-2 gap-3">
          {
            useCases.map((u) => (
              <li class="card px-4 py-3.5 text-[0.9rem] font-medium">{u}</li>
            ))
          }
        </ul>
        <p class="mt-6 text-sm leading-relaxed text-muted">
          Watching the console is one permission. Touching the keyboard, power, or boot settings is another, and those
          always wait for your approval in ACT. Compatibility depends on your hardware and setup.
        </p>
      </div>
    </div>
  </section>

  <section class="border-b border-hairline">
    <div class="container-site grid items-center gap-12 py-16 sm:py-24 lg:grid-cols-[minmax(0,1fr)_auto]">
      <div>
        <SectionHeader
          eyebrow="The real approval surface"
          title="Node actions land on your phone."
          sub="This is the real ACT app reviewing a high-risk request on a demo workspace. You can see the tool, the machine, the session, and when the request expires. Console, power, and boot requests from AgenticKVM show up the same way."
        />
      </div>
      <ProductShot
        src={actApprovalDetail}
        alt="The ACT iOS app reviewing a high-risk shell command approval in a demo workspace, with the request state, tool, agent, node, session, expiry, and a redacted payload. KVM console, power, and boot requests arrive in the same format."
        width={300}
        caption="Actual app · demo workspace"
        class="justify-self-center"
      />
    </div>
  </section>

  <section>
    <div class="container-site flex flex-wrap items-center justify-between gap-6 py-16 sm:py-20">
      <p class="max-w-lg text-lg font-medium text-balance">
        When SSH is dead, <span class="text-ember">AgenticKVM can still reach the console you already have.</span>
      </p>
      <a href="https://github.com/MahdiHedhli/AgenticKVM" class="btn btn-ink">View AgenticKVM on GitHub</a>
    </div>
  </section>
</Base>
