---
import Base from "../layouts/Base.astro";
import Badge from "../components/Badge.astro";
import SectionHeader from "../components/SectionHeader.astro";
import AgenticKVMDemo from "../components/AgenticKVMDemo.astro";
import DemoTimeline from "../components/DemoTimeline.astro";
import ProductShot from "../components/ProductShot.astro";
import actApprovalDetail from "../assets/product/act-approval-detail.png";

const useCases = [
  "Homelab recovery",
  "VM host troubleshooting",
  "Server console operations",
  "Boot recovery",
  "Network lockout recovery",
  "Remote machine triage",
  "Out-of-band visibility",
  "Controlled infrastructure ops",
];
---

<Base
  title="AgenticKVM — recover systems when normal access is gone | AgenticSuite"
  description="AgenticKVM gives agents a controlled path through PiKVM, BMC, Redfish, IPMI, and VM host consoles — to see and operate machines when SSH, APIs, and browsers can't."
>
  <section class="band-night relative overflow-hidden">
    <div class="container-site relative pt-16 pb-16 sm:pt-24">
      <div class="mx-auto max-w-3xl text-center">
        <Badge label="AgenticKVM · The out-of-band operator · Public beta" tone="beta" dark />
        <h1 class="mt-6 text-4xl leading-[1.06] font-semibold tracking-tight text-balance text-night-ink sm:text-[3.4rem]">
          Recover systems when normal access is gone.
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-night-muted">
          LLMs usually stop when SSH, APIs, or browser access fail. AgenticKVM gives them a controlled path to see and
          operate the machine through the same recovery surfaces an operator would use.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3.5">
          <a href="#demo" class="btn btn-primary">Watch a recovery</a>
          <a href="https://github.com/MahdiHedhli/AgenticKVM" class="btn border-night-hairline text-night-ink hover:border-night-muted">
            View on GitHub
          </a>
        </div>
      </div>
      <div id="demo" class="mx-auto mt-14 max-w-5xl">
        <AgenticKVMDemo />
      </div>
    </div>
  </section>

  <section class="border-b border-hairline bg-surface">
    <div class="container-site grid gap-12 py-16 sm:py-24 lg:grid-cols-2">
      <div>
        <SectionHeader
          eyebrow="From prompt to console"
          title="Eyes and hands at the console."
          sub="When the machine won't answer, AgenticKVM works through out-of-band surfaces — PiKVM, BMC, Redfish, IPMI, iLO- and iDRAC-style controllers, and VM host consoles — in compatible environments you already control."
        />
        <DemoTimeline
          class="mt-8"
          approvalIndex={3}
          steps={[
            "Ping and SSH fail — the normal paths are dead",
            "The agent attaches to the console in observe mode",
            "It reads the screen and diagnoses the failure",
            "Keyboard, power, boot, and VM host actions wait for your approval",
            "The approved action runs, the machine comes back",
            "An incident summary lands in the audit trail",
          ]}
        />
      </div>
      <div>
        <SectionHeader eyebrow="Where it shines" title="Built for the moments dashboards can't reach." />
        <ul class="mt-8 grid grid-cols-2 gap-3">
          {
            useCases.map((u) => (
              <li class="card px-4 py-3.5 text-[0.9rem] font-medium">{u}</li>
            ))
          }
        </ul>
        <p class="mt-6 text-sm leading-relaxed text-muted">
          Observation and control are clearly separated: watching a console is one permission, touching keyboard,
          power, or boot state is another — and the consequential ones always route through ACT. Compatibility varies
          by hardware and environment.
        </p>
      </div>
    </div>
  </section>

  <section class="border-b border-hairline">
    <div class="container-site grid items-center gap-12 py-16 sm:py-24 lg:grid-cols-[minmax(0,1fr)_auto]">
      <div>
        <SectionHeader
          eyebrow="The real approval surface"
          title="Node actions land on your phone."
          sub="This is the actual ACT app reviewing a high-risk request on a demo workspace — the tool, the node, the session, a redacted payload, and an expiry. High-risk console, power, and boot actions for AgenticKVM arrive in exactly the same format."
        />
      </div>
      <ProductShot
        src={actApprovalDetail}
        alt="The ACT iOS app reviewing a high-risk shell-command approval in a demo workspace: request summary with state, tool, agent, node, session and expiry, plus a redacted payload — KVM console, power, and boot requests arrive in the same format"
        width={300}
        caption="Actual app · demo workspace"
        class="justify-self-center"
      />
    </div>
  </section>

  <section>
    <div class="container-site flex flex-wrap items-center justify-between gap-6 py-16 sm:py-20">
      <p class="max-w-lg text-lg font-medium text-balance">
        When SSH is dead, <span class="text-ember">AgenticKVM can still reach the console you already have.</span>
      </p>
      <a href="https://github.com/MahdiHedhli/AgenticKVM" class="btn btn-ink">View AgenticKVM on GitHub</a>
    </div>
  </section>
</Base>
