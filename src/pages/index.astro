---
import Base from "../layouts/Base.astro";
import Badge from "../components/Badge.astro";
import SectionHeader from "../components/SectionHeader.astro";
import DeviceFrame from "../components/DeviceFrame.astro";
import PhoneApprovalMock from "../components/PhoneApprovalMock.astro";
import StatusRail from "../components/StatusRail.astro";
import ProductCard from "../components/ProductCard.astro";
import BrowserBridgeDemo from "../components/BrowserBridgeDemo.astro";
import AgenticKVMDemo from "../components/AgenticKVMDemo.astro";
import ACTDemo from "../components/ACTDemo.astro";
import DemoTimeline from "../components/DemoTimeline.astro";
import HermesIntegrationFlow from "../components/HermesIntegrationFlow.astro";
import IntegrationChip from "../components/IntegrationChip.astro";
import SecurityPill from "../components/SecurityPill.astro";

const integrations = [
  { name: "Hermes", relation: "Integration path for agent runtimes" },
  { name: "Claude Code", relation: "Designed for local agent runtimes" },
  { name: "MCP", relation: "First-class tool exposure where supported" },
  { name: "BrowserBridge", relation: "Chrome extension + local companion" },
  { name: "PiKVM", relation: "Supported console provider" },
  { name: "Redfish", relation: "Adapter for Redfish-compatible BMCs" },
  { name: "IPMI", relation: "Adapter for IPMI-compatible BMCs" },
  { name: "BMC consoles", relation: "Works with compatible environments" },
  { name: "iLO", relation: "Via the Redfish/IPMI adapters" },
  { name: "iDRAC", relation: "Via the Redfish/IPMI adapters" },
  { name: "VM hosts", relation: "Console and power control where supported" },
  { name: "GitHub", relation: "Source, issues, and docs" },
  { name: "Tailscale", relation: "Works with private tailnet-style networks" },
  { name: "Local network tools", relation: "Designed for local-first setups" },
  { name: "Homelab infrastructure", relation: "A natural home for the suite" },
];

const steps = [
  { name: "Prompt", copy: "Ask your agent to complete a task." },
  { name: "Plan", copy: "The agent decides what it needs to do across browsers, machines, or workflows." },
  { name: "Approval", copy: "ACT pauses consequential actions and asks for your approval." },
  { name: "Action", copy: "Approved actions run through BrowserBridge, AgenticKVM, Hermes, or MCP tools." },
  { name: "Audit", copy: "Every important request, decision, and action leaves a record." },
];

const security = [
  { title: "Human approval", copy: "Consequential actions pause for review." },
  { title: "Scoped access", copy: "Agents get only the permission needed for the task." },
  { title: "Signed decisions", copy: "Approvals are explicit and traceable." },
  { title: "One-time consumption", copy: "Clearances are used for the action they were issued for." },
  { title: "Fail-closed defaults", copy: "When control is uncertain, the system stops." },
  {
    title: "Observe before control",
    copy: "Especially for KVM and infrastructure work, observation and action are clearly separated.",
  },
  { title: "Audit trail", copy: "Requests, decisions, and actions are recorded." },
  { title: "Panic and revoke", copy: "Stop risky browser or system activity where supported." },
];
---

<Base
  title="AgenticSuite — AI agents that can actually do the work"
  description="AgenticSuite gives AI controlled access to your browser, computers, servers, and workflows, with ACT approvals for the actions that matter."
>
  <!-- ============ HERO ============ -->
  <section class="relative overflow-hidden">
    <div class="glow-field" aria-hidden="true"></div>
    <div class="container-site relative pt-16 pb-14 sm:pt-24 sm:pb-20">
      <div class="mx-auto max-w-3xl text-center">
        <Badge label="Public beta now open" tone="beta" />
        <h1 class="mt-6 text-[2.6rem] leading-[1.05] font-semibold tracking-tight text-balance sm:text-6xl lg:text-[4.2rem]">
          AI agents that can actually do the work.
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-muted text-pretty sm:text-xl">
          AgenticSuite gives AI controlled access to your browser, computers, servers, and workflows, with ACT
          approvals for the actions that matter.
        </p>
        <div class="mt-9 flex flex-wrap items-center justify-center gap-3.5">
          <a href="#demos" class="btn btn-primary">Watch it work</a>
          <a href="#how-it-works" class="btn btn-ghost">See how control works</a>
        </div>
      </div>

      <!-- split-scene: browser · phone · console -->
      <div class="relative mx-auto mt-16 max-w-5xl sm:mt-20">
        <div
          class="absolute top-1/2 right-8 left-8 hidden border-t border-dashed border-ink/15 lg:block"
          aria-hidden="true"
        >
        </div>
        <div class="relative grid items-center gap-6 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)_minmax(0,1.15fr)]">
          <DeviceFrame
            kind="browser"
            label="BrowserBridge filling a web form with the submit step paused for approval"
            address="clinics.example/appointments"
            class="float-soft"
          >
            <div class="space-y-2.5 bg-surface p-4">
              <p class="text-[0.68rem] font-semibold tracking-[0.08em] text-muted uppercase">Booking form</p>
              {
                ["Jordan Ellis", "(555) 014-2233", "Mon 8:15 AM — Lakeview Health"].map((v) => (
                  <div class="rounded-lg border border-hairline bg-bg/50 px-3 py-1.5 text-[0.74rem]">{v}</div>
                ))
              }
              <div class="flex items-center gap-2.5 pt-1">
                <span class="rounded-full bg-ink px-3.5 py-1.5 text-[0.72rem] font-semibold text-white">Submit</span>
                <span class="inline-flex items-center gap-1.5 rounded-full bg-beacon/15 px-2.5 py-1 text-[0.64rem] font-semibold text-ember">
                  <span class="status-dot bg-beacon" aria-hidden="true"></span>Paused for approval
                </span>
              </div>
            </div>
          </DeviceFrame>

          <PhoneApprovalMock class="z-10 mx-auto w-full max-w-56 lg:-my-4" />

          <DeviceFrame
            kind="console"
            label="AgenticKVM console showing a server brought back online"
            title="agentickvm — pve01"
            class="float-soft-delay"
          >
            <div class="console-text space-y-1 p-4 text-night-muted">
              <p>$ ssh root@pve01 <span class="text-[#f2a099]">· timed out</span></p>
              <p class="text-night-ink">→ opening PiKVM console…</p>
              <p>observing boot… stale initramfs found</p>
              <p class="text-night-ink">→ approved: select previous kernel</p>
              <p class="text-[#7ee2a0]">pve01 login: _ · back online</p>
            </div>
          </DeviceFrame>
        </div>
      </div>

      <StatusRail class="mt-12" />
    </div>
  </section>

  <!-- ============ INTRO STATEMENT ============ -->
  <section class="border-y border-hairline bg-surface">
    <div class="container-site py-16 sm:py-20">
      <p class="mx-auto max-w-3xl text-center text-2xl leading-snug font-semibold tracking-tight text-balance sm:text-[2rem]">
        Most AI agents stop at advice.<br class="hidden sm:block" />
        <span class="text-ember">AgenticSuite gives them controlled paths to act.</span>
      </p>
      <ul class="mx-auto mt-8 flex max-w-3xl flex-wrap items-center justify-center gap-2.5" aria-label="Work surfaces">
        {
          ["Your browser", "Your computers", "Your servers & VM hosts", "Your workflows", "Your agent runtimes"].map(
            (s) => (
              <li class="chip">
                <span class="chip-dot" aria-hidden="true" />
                {s}
              </li>
            ),
          )
        }
      </ul>
    </div>
  </section>

  <!-- ============ PRODUCT PILLARS ============ -->
  <section id="products">
    <div class="container-site py-20 sm:py-28">
      <SectionHeader
        eyebrow="The suite"
        title="Three products. One control layer."
        sub="Let AI do the hard parts. Approve what matters."
        align="center"
      />
      <div class="mt-14 grid gap-6 lg:grid-cols-3">
        <ProductCard
          name="ACT"
          subtitle="The approval layer"
          headline="Approve what matters."
          copy="ACT turns consequential agent actions into clear approval requests on your phone. Approve, modify, or deny before anything sensitive happens."
          credibility="Signed, single-use approvals with a complete audit trail."
          href="/act"
          demoHref="#demo-act"
        >
          <div class="mx-auto w-40">
            <PhoneApprovalMock
              summary="Reboot pve01?"
              action="Power cycle via BMC"
              risk="High"
              scope="pve01 only"
              expires="2 minutes"
              label="Small phone mockup with an ACT approval request"
            />
          </div>
        </ProductCard>

        <ProductCard
          name="BrowserBridge"
          subtitle="The browser operator"
          headline="Give AI your browser, not your trust."
          copy="Let AI browse, click, compare, fill, and complete web tasks in your real browser — and pause before sensitive actions like submitting."
          credibility="Runs in your own session. Panic control revokes in-flight authority."
          href="/browserbridge"
          demoHref="#demo-browserbridge"
        >
          <div class="space-y-2 rounded-xl border border-hairline bg-surface p-3.5">
            <div class="flex items-center gap-2">
              <span class="flex gap-1" aria-hidden="true">
                <span class="h-2 w-2 rounded-full bg-hairline"></span>
                <span class="h-2 w-2 rounded-full bg-hairline"></span>
              </span>
              <span class="flex-1 rounded-full border border-hairline bg-bg px-2.5 py-0.5 text-[0.62rem] text-muted">
                portal.example/renewal
              </span>
            </div>
            {["Account verified", "Form filled — 6 fields", "Compared 3 plan options"].map((t) => (
              <p class="flex items-center gap-2 text-[0.72rem] text-muted">
                <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="text-ember">
                  <path d="m2.5 6.5 2.5 2.5 4.5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                </svg>
                {t}
              </p>
            ))}
            <p class="inline-flex items-center gap-1.5 rounded-full bg-beacon/15 px-2.5 py-1 text-[0.64rem] font-semibold text-ember">
              <span class="status-dot bg-beacon" aria-hidden="true"></span>Paused before checkout
            </p>
          </div>
        </ProductCard>

        <ProductCard
          name="AgenticKVM"
          subtitle="The out-of-band operator"
          headline="Operate beyond SSH."
          copy="Give agents a controlled path to operate computers, servers, and VM hosts when normal access is not enough — through the same consoles an operator would use."
          credibility="Adapters for PiKVM, Redfish, IPMI, and BMC-style consoles."
          href="/agentickvm"
          demoHref="#demo-agentickvm"
        >
          <div class="console-text space-y-1 rounded-xl border border-night-hairline bg-night p-3.5 text-night-muted">
            <p>$ ping pve01 <span class="text-[#f2a099]">· timeout</span></p>
            <p class="text-night-ink">→ PiKVM console attached</p>
            <p>observe: boot halted at initramfs</p>
            <p class="text-night-ink">→ ACT approval · keys sent</p>
            <p class="text-[#7ee2a0]">recovered · summary written</p>
          </div>
        </ProductCard>
      </div>
    </div>
  </section>

  <!-- ============ DEMOS ============ -->
  <section id="demos" class="border-t border-hairline bg-surface">
    <div class="container-site py-20 sm:py-28">
      <SectionHeader
        eyebrow="Product demonstrations"
        title="Watch AgenticSuite work."
        sub="Three real-world workflows. One control layer."
        align="center"
      />

      <!-- Demo A: BrowserBridge -->
      <div id="demo-browserbridge" class="mt-16 grid items-center gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.5fr)]">
        <div class="min-w-0">
          <p class="eyebrow">Demo · BrowserBridge</p>
          <h3 class="mt-2 text-2xl font-semibold tracking-tight sm:text-3xl">
            Watch AI complete a browser task, safely.
          </h3>
          <p class="mt-3 rounded-2xl border border-hairline bg-bg px-4 py-3 text-[0.9rem] text-muted italic">
            “Find the earliest available appointment within 25 miles and fill the form, but stop before submitting.”
          </p>
          <DemoTimeline
            class="mt-6"
            approvalIndex={4}
            steps={[
              "Opens the browser and navigates to the site",
              "Searches and compares locations and times",
              "Fills the safe fields",
              "Pauses before submission",
              "You approve from your phone",
              "BrowserBridge submits — task complete, audit recorded",
            ]}
          />
        </div>
        <BrowserBridgeDemo />
      </div>

      <!-- Demo B: AgenticKVM -->
      <div id="demo-agentickvm" class="band-night mt-20 rounded-[2rem] p-6 sm:p-10">
        <div class="grid items-center gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.6fr)]">
          <div class="min-w-0">
            <p class="eyebrow !text-beacon">Demo · AgenticKVM</p>
            <h3 class="mt-2 text-2xl font-semibold tracking-tight text-night-ink sm:text-3xl">
              Recover systems when normal access is gone.
            </h3>
            <p class="mt-3 rounded-2xl border border-night-hairline bg-night-surface px-4 py-3 text-[0.9rem] text-night-muted italic">
              “pve01 stopped responding after the kernel update. Diagnose from the console and recover safely. Ask
              before changing boot or power state.”
            </p>
            <DemoTimeline
              class="mt-6"
              dark
              approvalIndex={3}
              steps={[
                "Ping and SSH fail — normal access is gone",
                "The agent opens a PiKVM/BMC console in observe mode",
                "It reads the boot failure and identifies the likely cause",
                "You approve the recovery action from your phone",
                "Keys are sent, the machine boots, access is restored",
                "An incident summary is written to the audit trail",
              ]}
            />
          </div>
          <AgenticKVMDemo />
        </div>
      </div>

      <!-- Demo C: ACT -->
      <div id="demo-act" class="mt-20">
        <div class="mx-auto mb-10 max-w-xl text-center">
          <p class="eyebrow">Demo · ACT</p>
          <h3 class="mt-2 text-2xl font-semibold tracking-tight sm:text-3xl">Approve what matters from your phone.</h3>
          <p class="mt-3 text-muted">
            Requests arrive as plain-English cards. You approve, modify, or deny — and every decision is recorded.
          </p>
        </div>
        <ACTDemo />
      </div>
    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section id="how-it-works" class="border-t border-hairline">
    <div class="container-site py-20 sm:py-28">
      <SectionHeader
        eyebrow="How it works"
        title="How AgenticSuite turns prompts into controlled action."
        sub="Prompt. Plan. Approve. Act. Audit."
        align="center"
      />
      <ol class="mx-auto mt-14 grid max-w-5xl gap-4 sm:grid-cols-2 lg:grid-cols-5">
        {
          steps.map(({ name, copy }, i) => (
            <li class:list={["card p-5", i === 2 && "border-beacon/50 bg-beacon/8"]}>
              <span
                class:list={[
                  "flex h-8 w-8 items-center justify-center rounded-full text-[0.8rem] font-bold",
                  i === 2 ? "bg-beacon text-[#221503]" : "bg-bg text-muted",
                ]}
                aria-hidden="true"
              >
                {i + 1}
              </span>
              <h3 class="mt-3.5 font-semibold">{name}</h3>
              <p class="mt-1 text-[0.84rem] leading-relaxed text-muted">{copy}</p>
            </li>
          ))
        }
      </ol>

      <details class="group mx-auto mt-8 max-w-3xl rounded-2xl border border-hairline bg-surface">
        <summary
          class="flex cursor-pointer list-none items-center justify-between gap-3 px-6 py-4 text-[0.95rem] font-semibold [&::-webkit-details-marker]:hidden"
        >
          For the technically curious
          <svg
            width="14"
            height="14"
            viewBox="0 0 14 14"
            fill="none"
            aria-hidden="true"
            class="transition-transform group-open:rotate-180"
          >
            <path d="m2 5 5 5 5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
          </svg>
        </summary>
        <div class="border-t border-hairline px-6 py-5 text-sm leading-relaxed text-muted">
          <ul class="space-y-2">
            <li><strong class="text-ink">Scoped clearances</strong> — each approval covers one capability, not blanket access.</li>
            <li><strong class="text-ink">Signed approvals</strong> — decisions are cryptographically signed on your device.</li>
            <li><strong class="text-ink">One-time use</strong> — a clearance is consumed by the action it was issued for.</li>
            <li><strong class="text-ink">Provider-specific permissions</strong> — browser, console, and workflow surfaces each declare what they can do.</li>
            <li><strong class="text-ink">Fail-closed behavior</strong> — a missing or unverified clearance means no action.</li>
            <li><strong class="text-ink">Audit trail</strong> — requests, decisions, and actions are recorded for review.</li>
          </ul>
        </div>
      </details>
    </div>
  </section>

  <!-- ============ INTEGRATIONS ============ -->
  <section id="integrations" class="border-t border-hairline bg-surface">
    <div class="container-site py-20 sm:py-28">
      <SectionHeader
        eyebrow="Integrations"
        title="Built to connect with the tools agents already use."
        sub="AgenticSuite gives agent runtimes a controlled path into browsers, machines, and workflows."
        align="center"
      />
      <HermesIntegrationFlow class="mt-14" />
      <ul class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5" aria-label="Integrations and compatible surfaces">
        {integrations.map(({ name, relation }) => <IntegrationChip {name} {relation} />)}
      </ul>
      <p class="mt-6 text-center text-[0.78rem] text-muted">
        Compatibility varies by environment and configuration. Product names belong to their owners; no partnership implied.
      </p>
    </div>
  </section>

  <!-- ============ SECURITY ============ -->
  <section id="security" class="border-t border-hairline">
    <div class="container-site py-20 sm:py-28">
      <SectionHeader
        eyebrow="Security"
        title="Control is built in."
        sub="AgenticSuite is designed around human approval, scoped permissions, and visible records. Control is not an afterthought — it is the product."
        align="center"
      />
      <ul class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {security.map(({ title, copy }) => <SecurityPill {title} {copy} />)}
      </ul>
    </div>
  </section>

  <!-- ============ DEVELOPERS ============ -->
  <section id="developers" class="band-night">
    <div class="container-site py-20 sm:py-24">
      <div class="grid items-center gap-10 lg:grid-cols-[minmax(0,1.3fr)_minmax(0,1fr)]">
        <div>
          <p class="eyebrow !text-beacon">Developers</p>
          <h2 class="mt-3 text-3xl font-semibold tracking-tight text-night-ink sm:text-[2.4rem]">Built for builders.</h2>
          <p class="mt-4 max-w-xl text-lg leading-relaxed text-night-muted">
            AgenticSuite exposes controlled action surfaces for agent runtimes, automations, and local-first
            infrastructure. Route browser actions, KVM operations, and workflow steps through ACT approvals and
            auditable execution paths.
          </p>
          <ul class="mt-6 flex flex-wrap gap-2.5">
            {
              ["Public beta", "Self-hosted & local-first", "MCP where supported", "Open protocols on GitHub"].map(
                (t) => (
                  <li class="rounded-full border border-night-hairline bg-night-surface px-3.5 py-1.5 text-[0.78rem] font-medium text-night-muted">
                    {t}
                  </li>
                ),
              )
            }
          </ul>
          <div class="mt-8 flex flex-wrap gap-3.5">
            <a href="https://github.com/MahdiHedhli" class="btn btn-primary">Start on GitHub</a>
            <a
              href="https://github.com/MahdiHedhli/AgenticControlTower"
              class="btn border-night-hairline text-night-ink hover:border-night-muted"
            >
              ACT docs & source
            </a>
          </div>
        </div>
        <div class="card-night console-text space-y-1.5 p-6 text-night-muted">
          <p class="text-night-ink"># connect a runtime to controlled surfaces</p>
          <p>agent → act(approval) # direct, or via hermes</p>
          <p>&nbsp;&nbsp;├─ browserbridge · web tasks</p>
          <p>&nbsp;&nbsp;├─ agentickvm · consoles & power</p>
          <p>&nbsp;&nbsp;└─ mcp tools · where supported</p>
          <p class="text-night-ink"># every action → audit trail</p>
        </div>
      </div>
    </div>
  </section>
</Base>
