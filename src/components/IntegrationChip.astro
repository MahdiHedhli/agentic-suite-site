---
interface Props {
  name: string;
  relation: string; // accurate wording: "integrates with", "adapter for", …
}
const { name, relation } = Astro.props;
---

<li class="card flex flex-col gap-0.5 px-5 py-4">
  <span class="text-[0.95rem] font-semibold tracking-tight">{name}</span>
  <span class="text-[0.78rem] text-muted">{relation}</span>
</li>
