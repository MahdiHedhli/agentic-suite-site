---
const products = [
  { href: "/act", label: "ACT", sub: "The approval layer" },
  { href: "/browserbridge", label: "BrowserBridge", sub: "The browser operator" },
  { href: "/agentickvm", label: "AgenticKVM", sub: "The out-of-band operator" },
];

const links = [
  { href: "/#demos", label: "Demos" },
  { href: "/#how-it-works", label: "How it works" },
  { href: "/#security", label: "Security" },
  { href: "/#developers", label: "Developers" },
  { href: "https://github.com/MahdiHedhli", label: "GitHub" },
];
---

<header class="sticky top-0 z-50 border-b border-hairline bg-bg/80 backdrop-blur-xl">
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-3 px-3 sm:px-6" aria-label="Main">
    <a href="/" class="flex items-center gap-2.5 text-[1.02rem] font-semibold tracking-tight">
      <span class="beacon-dot" aria-hidden="true"></span>
      AgenticSuite
    </a>

    <div class="hidden items-center gap-1 md:flex">
      <!-- Products disclosure: opens on click, Escape / click-away closes -->
      <details class="group relative" data-nav-menu>
        <summary
          class="flex cursor-pointer list-none items-center gap-1.5 rounded-full px-3.5 py-2 text-[0.9rem] font-medium text-muted transition-colors group-open:bg-surface group-open:text-ink hover:bg-surface hover:text-ink [&::-webkit-details-marker]:hidden"
        >
          Products
          <svg
            width="10"
            height="10"
            viewBox="0 0 12 12"
            fill="none"
            aria-hidden="true"
            class="mt-0.5 transition-transform group-open:rotate-180"
          >
            <path d="m2 4 4 4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
          </svg>
        </summary>
        <div class="absolute left-0 z-50 w-72 pt-2">
          <div class="card flex flex-col gap-0.5 p-2 shadow-xl">
            {
              products.map(({ href, label, sub }) => (
                <a href={href} class="rounded-xl px-3.5 py-2.5 hover:bg-bg">
                  <span class="block text-[0.92rem] font-semibold text-ink">{label}</span>
                  <span class="block text-[0.78rem] text-muted">{sub}</span>
                </a>
              ))
            }
            <a
              href="/#products"
              class="rounded-xl border-t border-hairline px-3.5 py-2.5 text-[0.82rem] font-medium text-muted hover:bg-bg hover:text-ink"
            >
              Suite overview →
            </a>
          </div>
        </div>
      </details>

      {
        links.map(({ href, label }) => (
          <a
            href={href}
            class="rounded-full px-3.5 py-2 text-[0.9rem] font-medium text-muted transition-colors hover:bg-surface hover:text-ink"
          >
            {label}
          </a>
        ))
      }
      <a href="/#demos" class="btn btn-ink ml-2 !px-4 !py-2 !text-[0.85rem]">Watch it work</a>
    </div>

    <details class="relative md:hidden" data-nav-menu>
      <summary
        class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-full border border-hairline bg-surface [&::-webkit-details-marker]:hidden"
        aria-label="Menu"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M2 4.5h12M2 8h12M2 11.5h12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
        </svg>
      </summary>
      <div class="card absolute right-0 mt-3 flex w-64 flex-col gap-0.5 p-2 shadow-xl">
        <p class="px-3.5 pt-2 pb-1 text-[0.68rem] font-semibold tracking-[0.12em] text-muted uppercase">Products</p>
        {
          products.map(({ href, label, sub }) => (
            <a href={href} class="rounded-xl px-3.5 py-2 hover:bg-bg">
              <span class="block text-[0.9rem] font-semibold text-ink">{label}</span>
              <span class="block text-[0.75rem] text-muted">{sub}</span>
            </a>
          ))
        }
        <p class="mt-1 border-t border-hairline px-3.5 pt-2 pb-1 text-[0.68rem] font-semibold tracking-[0.12em] text-muted uppercase">
          Explore
        </p>
        {
          links.map(({ href, label }) => (
            <a href={href} class="rounded-xl px-3.5 py-2 text-[0.92rem] font-medium text-ink hover:bg-bg">
              {label}
            </a>
          ))
        }
      </div>
    </details>
  </nav>
</header>

<script>
  // Close nav disclosures on Escape or click-away (a11y: WCAG 1.4.13 dismissibility).
  const menus = [...document.querySelectorAll<HTMLDetailsElement>("details[data-nav-menu]")];
  document.addEventListener("keydown", (e) => {
    if (e.key !== "Escape") return;
    for (const menu of menus) {
      if (!menu.open) continue;
      const hadFocus = menu.contains(document.activeElement);
      menu.open = false;
      if (hadFocus) menu.querySelector("summary")?.focus();
    }
  });
  document.addEventListener("click", (e) => {
    for (const menu of menus) {
      if (menu.open && e.target instanceof Node && !menu.contains(e.target)) menu.open = false;
    }
  });
</script>
