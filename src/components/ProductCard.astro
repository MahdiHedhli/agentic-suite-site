---
/** Large product pillar card for the homepage. */
interface Props {
  name: string;
  subtitle: string;
  headline: string;
  copy: string;
  credibility: string;
  href: string;
  demoHref: string;
}
const { name, subtitle, headline, copy, credibility, href, demoHref } = Astro.props;
---

<article class="card flex flex-col overflow-hidden">
  <div class="border-b border-hairline bg-bg/50 p-5">
    <slot />
  </div>
  <div class="flex flex-1 flex-col p-7">
    <p class="eyebrow">{subtitle}</p>
    <h3 class="mt-2 text-2xl font-semibold tracking-tight">{name}</h3>
    <p class="mt-2 text-[1.05rem] font-medium text-balance">{headline}</p>
    <p class="mt-2.5 text-sm leading-relaxed text-muted">{copy}</p>
    <p class="mt-3 flex items-start gap-2 text-[0.8rem] text-muted">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="mt-0.5 flex-none text-ember">
        <path
          d="M8 1.5 3 3.5v4c0 3.2 2.1 5.7 5 7 2.9-1.3 5-3.8 5-7v-4L8 1.5Z"
          stroke="currentColor"
          stroke-width="1.4"
          stroke-linejoin="round"></path>
      </svg>
      {credibility}
    </p>
    <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-2 pt-1">
      <a href={href} class="text-sm font-semibold text-ink underline-offset-4 hover:underline">
        Learn more<span class="sr-only"> about {name}</span> →
      </a>
      <a href={demoHref} class="text-sm font-medium text-muted hover:text-ink">
        Jump to demo<span class="sr-only"> for {name}</span>
      </a>
    </div>
  </div>
</article>
