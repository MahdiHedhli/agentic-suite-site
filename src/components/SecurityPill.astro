---
interface Props {
  title: string;
  copy: string;
}
const { title, copy } = Astro.props;
---

<li class="card p-6">
  <span
    class="flex h-9 w-9 items-center justify-center rounded-xl bg-beacon/12 text-ember"
    aria-hidden="true"
  >
    <slot>
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path
          d="M8 1.5 3 3.5v4c0 3.2 2.1 5.7 5 7 2.9-1.3 5-3.8 5-7v-4L8 1.5Z"
          stroke="currentColor"
          stroke-width="1.4"
          stroke-linejoin="round"></path>
      </svg>
    </slot>
  </span>
  <h3 class="mt-4 text-[1.02rem] font-semibold tracking-tight">{title}</h3>
  <p class="mt-1.5 text-sm leading-relaxed text-muted">{copy}</p>
</li>
