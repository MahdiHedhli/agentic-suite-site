---
interface Props {
  label: string;
  tone?: "neutral" | "beta" | "ok" | "review";
  dark?: boolean;
}

const { label, tone = "neutral", dark = false } = Astro.props;

const dotColor = {
  neutral: "var(--color-muted)",
  beta: "var(--color-beacon)",
  ok: "var(--color-ok)",
  review: "var(--color-beacon)",
}[tone];
---

<span
  class:list={[
    "chip",
    dark && "!border-night-hairline !bg-night-surface !text-night-muted",
  ]}
>
  <span class="chip-dot" style={`background:${dotColor}`} aria-hidden="true"></span>{label}
</span>
