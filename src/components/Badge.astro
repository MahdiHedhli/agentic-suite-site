---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<span
  class="inline-flex items-center gap-2 border border-hairline bg-surface px-2.5 py-1 font-mono text-[0.68rem] font-medium tracking-[0.14em] uppercase text-muted"
>
  <span class="h-1.5 w-1.5 rounded-full bg-beacon" aria-hidden="true"></span>{label}
</span>
