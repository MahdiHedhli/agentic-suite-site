---
interface Props {
  eyebrow?: string;
  title: string;
  sub?: string;
  align?: "left" | "center";
}

const { eyebrow, title, sub, align = "left" } = Astro.props;
---

<div class:list={["max-w-2xl", align === "center" && "mx-auto text-center"]}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="mt-3 text-3xl font-semibold tracking-tight text-balance sm:text-[2.6rem] sm:leading-[1.12]">{title}</h2>
  {sub && <p class="mt-4 text-lg leading-relaxed text-muted text-pretty">{sub}</p>}
</div>
