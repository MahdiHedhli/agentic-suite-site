---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

/**
 * A real product screenshot, framed to match the site's device language.
 * kind "phone" wraps in the generic phone frame; "panel" is a soft card
 * for browser-extension / desktop panels.
 */
interface Props {
  src: ImageMetadata;
  alt: string;
  kind?: "phone" | "panel";
  caption?: string;
  width?: number;
  class?: string;
}

const { src, alt, kind = "phone", caption, width = kind === "phone" ? 380 : 500, class: className } = Astro.props;
---

<figure class:list={["flex flex-col items-center gap-3", className]}>
  {
    kind === "phone" ? (
      <div class="overflow-hidden rounded-[2.2rem] border border-ink/10 bg-night p-1.5 shadow-[0_30px_70px_-30px_rgba(22,25,31,0.45)]">
        <Image {src} {alt} {width} class="rounded-[1.85rem]" />
      </div>
    ) : (
      <div class="overflow-hidden rounded-3xl border border-hairline bg-surface p-1.5 shadow-[0_24px_60px_-30px_rgba(22,25,31,0.3)]">
        <Image {src} {alt} {width} class="rounded-[1.4rem]" />
      </div>
    )
  }
  {caption && <figcaption class="chip">{caption}</figcaption>}
</figure>
