---
import DeviceFrame from "./DeviceFrame.astro";

/**
 * Product demonstration: BrowserBridge completes a browser task, pauses before
 * submit, gets ACT approval, then finishes. Pure CSS choreography on an 18s loop.
 * With prefers-reduced-motion the scene renders in its completed state.
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<div class:list={["bb-demo relative min-w-0 max-w-full", className]}>
  <DeviceFrame
    kind="browser"
    label="Product demo: BrowserBridge finds an appointment, fills the form, pauses before submitting, and finishes after ACT approval"
    address="clinics.example/appointments"
  >
    <div class="relative bg-surface p-4 sm:p-5">
      <p
        class="mb-4 inline-flex max-w-full items-center gap-2 rounded-full border border-hairline bg-bg px-3 py-1.5 text-[0.72rem] text-muted"
      >
        <span class="beacon-dot !h-1.5 !w-1.5" aria-hidden="true"></span>
        <span class="min-w-0 flex-1 truncate">“Find the earliest appointment within 25 miles and fill the form, but stop before submitting.”</span>
      </p>

      <div class="grid gap-4 sm:grid-cols-[minmax(0,1fr)_minmax(0,1.15fr)]">
        <!-- results -->
        <div class="min-w-0 space-y-2">
          <p class="text-[0.68rem] font-semibold tracking-[0.08em] text-muted uppercase">Available appointments</p>
          <div class="bb-r bb-r1 rounded-xl border border-hairline p-3">
            <p class="text-[0.78rem] font-semibold">Northside Clinic · 4.1 mi</p>
            <p class="text-[0.7rem] text-muted">Tue 9:40 AM</p>
          </div>
          <div class="bb-r bb-r2 bb-picked relative rounded-xl border border-hairline p-3">
            <p class="text-[0.78rem] font-semibold">Lakeview Health · 7.8 mi</p>
            <p class="text-[0.7rem] text-muted">Mon 8:15 AM · earliest</p>
            <span class="bb-pick-tag absolute -top-2 right-2 rounded-full bg-beacon px-2 py-0.5 text-[0.6rem] font-bold text-[#221503]"
              >Best match</span
            >
          </div>
          <div class="bb-r bb-r3 rounded-xl border border-hairline p-3">
            <p class="text-[0.78rem] font-semibold">Central Care · 12.3 mi</p>
            <p class="text-[0.7rem] text-muted">Wed 2:00 PM</p>
          </div>
        </div>

        <!-- form -->
        <div class="relative min-w-0 rounded-xl border border-hairline bg-bg/40 p-4">
          <div class="bb-success absolute inset-x-3 top-3 z-10 flex items-center gap-2 rounded-xl bg-ok-soft px-3 py-2 text-[0.75rem] font-semibold text-ok-deep">
            <svg width="13" height="13" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="m2.5 6.5 2.5 2.5 4.5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
            </svg>
            Submitted · Mon 8:15 AM confirmed
          </div>

          <p class="text-[0.68rem] font-semibold tracking-[0.08em] text-muted uppercase">Booking form</p>
          {
            [
              ["Full name", "Jordan Ellis", "bb-f1"],
              ["Phone", "(555) 014-2233", "bb-f2"],
              ["Preferred time", "Mon 8:15 AM · Lakeview Health", "bb-f3"],
            ].map(([field, value, cls]) => (
              <div class="mt-2.5">
                <p class="text-[0.66rem] text-muted">{field}</p>
                <div class="mt-1 rounded-lg border border-hairline bg-surface px-3 py-1.5 text-[0.76rem]">
                  <span class:list={["bb-fill inline-block", cls]}>{value}</span>
                </div>
              </div>
            ))
          }

          <div class="mt-3 flex items-center gap-2 text-[0.7rem] text-muted">
            <span class="bb-check flex h-4 w-4 items-center justify-center rounded border border-hairline bg-surface">
              <svg width="9" height="9" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="bb-check-mark text-ember">
                <path d="m2.5 6.5 2.5 2.5 4.5-5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"></path>
              </svg>
            </span>
            Text me a reminder
          </div>

          <div class="mt-4 flex items-center gap-3">
            <span class="bb-submit rounded-full bg-ink px-4 py-1.5 text-[0.75rem] font-semibold text-white">Submit</span>
            <span class="bb-pause inline-flex items-center gap-1.5 rounded-full bg-beacon/15 px-2.5 py-1 text-[0.66rem] font-semibold text-ember">
              <span class="status-dot bg-beacon" aria-hidden="true"></span>
              Paused for your approval
            </span>
          </div>
        </div>
      </div>

      <p class="bb-audit mt-4 inline-flex items-center gap-2 rounded-full border border-hairline bg-surface px-3 py-1 text-[0.68rem] text-muted">
        <span class="console-text !text-[0.62rem]">12:04:17</span> Approved by you · form submitted · recorded in audit trail
      </p>

      <!-- automation cursor -->
      <svg class="bb-cursor absolute z-20" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M3 2l11 5.5-4.8 1.4L7.5 14 3 2Z" fill="#16191F" stroke="#fff" stroke-width="1.2"></path>
      </svg>

      <!-- ACT approval overlay -->
      <div class="bb-act absolute right-4 bottom-4 z-30 w-60 rounded-2xl border border-hairline bg-surface p-3.5 shadow-xl">
        <p class="flex items-center gap-1.5 text-[0.68rem] font-semibold">
          <span class="beacon-dot !h-1.5 !w-1.5" aria-hidden="true"></span> ACT · approval request
        </p>
        <p class="mt-1.5 text-[0.74rem] leading-snug">Submit appointment form at clinics.example?</p>
        <p class="mt-1 flex items-center gap-1.5 text-[0.64rem] text-muted">
          <span class="status-dot" style="background:var(--color-beacon)" aria-hidden="true"></span>Medium risk · this form only · expires in 5 min
        </p>
        <div class="bb-act-buttons mt-2.5 grid grid-cols-2 gap-1.5 text-center text-[0.7rem] font-semibold">
          <span class="bb-act-approve rounded-full bg-ink px-2 py-1 text-white">Approve</span>
          <span class="rounded-full border border-hairline px-2 py-1 text-muted">Deny</span>
        </div>
      </div>
    </div>
  </DeviceFrame>
</div>

<style>
  /* one shared 18s clock; every element animates inside its % window; fill:both
     means reduced-motion (instant single run) rests on the completed scene */
  .bb-demo {
    --d: 18s;
  }

  .bb-r {
    animation: bb-rise var(--d) linear infinite both;
    opacity: 0;
  }
  /* fallback for any .bb-r without a per-element window */
  @keyframes bb-rise { 0%, 10% { opacity: 0; transform: translateY(6px); } 13%, 100% { opacity: 1; transform: none; } }
  .bb-r1 { animation-name: bb-r1; }
  .bb-r2 { animation-name: bb-r2; }
  .bb-r3 { animation-name: bb-r3; }
  @keyframes bb-r1 { 0%, 4% { opacity: 0; transform: translateY(6px); } 7%, 100% { opacity: 1; transform: none; } }
  @keyframes bb-r2 { 0%, 7% { opacity: 0; transform: translateY(6px); } 10%, 100% { opacity: 1; transform: none; } }
  @keyframes bb-r3 { 0%, 10% { opacity: 0; transform: translateY(6px); } 13%, 100% { opacity: 1; transform: none; } }

  .bb-picked { animation-name: bb-picked; }
  @keyframes bb-picked {
    0%, 7% { opacity: 0; transform: translateY(6px); border-color: var(--color-hairline); }
    10%, 15% { opacity: 1; transform: none; border-color: var(--color-hairline); box-shadow: none; }
    18%, 100% { opacity: 1; transform: none; border-color: var(--color-beacon); box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-beacon) 18%, transparent); }
  }
  /* scale-only reveal: text/background never blend mid-animation (axe-safe) */
  .bb-pick-tag { animation: bb-pick-tag var(--d) linear infinite both; transform: scale(0); }
  @keyframes bb-pick-tag { 0%, 16% { transform: scale(0); } 19%, 100% { transform: scale(1); } }

  .bb-fill { clip-path: inset(0 100% 0 0); animation: bb-fill var(--d) linear infinite both; }
  /* fallback reveal for any .bb-fill without a per-element window */
  @keyframes bb-fill { 0%, 40% { clip-path: inset(0 100% 0 0); } 46%, 100% { clip-path: inset(0 -4% 0 0); } }
  .bb-f1 { animation-name: bb-f1; }
  .bb-f2 { animation-name: bb-f2; }
  .bb-f3 { animation-name: bb-f3; }
  @keyframes bb-f1 { 0%, 22% { clip-path: inset(0 100% 0 0); } 28%, 100% { clip-path: inset(0 -4% 0 0); } }
  @keyframes bb-f2 { 0%, 30% { clip-path: inset(0 100% 0 0); } 36%, 100% { clip-path: inset(0 -4% 0 0); } }
  @keyframes bb-f3 { 0%, 38% { clip-path: inset(0 100% 0 0); } 44%, 100% { clip-path: inset(0 -4% 0 0); } }

  .bb-check-mark { animation: bb-check var(--d) linear infinite both; opacity: 0; }
  @keyframes bb-check { 0%, 46% { opacity: 0; transform: scale(0.5); } 49%, 100% { opacity: 1; transform: none; } }

  .bb-pause { animation: bb-pause var(--d) linear infinite both; opacity: 0; }
  @keyframes bb-pause { 0%, 51% { opacity: 0; } 54%, 72% { opacity: 1; } 76%, 100% { opacity: 0; } }

  .bb-submit { animation: bb-submit var(--d) linear infinite both; }
  @keyframes bb-submit {
    0%, 51% { box-shadow: none; }
    54%, 72% { box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-beacon) 35%, transparent); }
    76%, 100% { box-shadow: none; }
  }

  .bb-act { animation: bb-act var(--d) linear infinite both; opacity: 0; }
  @keyframes bb-act {
    0%, 55% { opacity: 0; transform: translateY(14px); }
    59%, 70% { opacity: 1; transform: none; }
    74%, 100% { opacity: 0; transform: translateY(6px); }
  }
  .bb-act-approve { animation: bb-act-approve var(--d) linear infinite both; }
  @keyframes bb-act-approve {
    0%, 65% { transform: none; background: var(--color-ink); }
    67%, 69% { transform: scale(0.94); background: #155d29; }
    71%, 100% { transform: none; }
  }

  .bb-success { animation: bb-success var(--d) linear infinite both; opacity: 0; }
  @keyframes bb-success { 0%, 77% { opacity: 0; transform: translateY(-6px); } 81%, 100% { opacity: 1; transform: none; } }

  .bb-audit { animation: bb-audit var(--d) linear infinite both; opacity: 0; }
  @keyframes bb-audit { 0%, 84% { opacity: 0; } 88%, 100% { opacity: 1; } }

  .bb-cursor { animation: bb-cursor var(--d) linear infinite both; opacity: 0; left: 10%; top: 30%; }
  @keyframes bb-cursor {
    0%, 3% { opacity: 0; left: 10%; top: 34%; }
    6% { opacity: 1; left: 14%; top: 40%; }
    16% { left: 22%; top: 52%; }
    22% { left: 58%; top: 38%; }
    30% { left: 62%; top: 46%; }
    38% { left: 64%; top: 56%; }
    46% { left: 60%; top: 68%; }
    52% { left: 56%; top: 78%; opacity: 1; }
    58%, 100% { opacity: 0; left: 56%; top: 78%; }
  }
</style>
