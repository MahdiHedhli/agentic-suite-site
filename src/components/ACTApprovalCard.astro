---
/**
 * A single ACT approval request card (mockup, presentational).
 * Risk is always shown as dot + word — never color alone.
 */
interface Props {
  summary: string;
  action: string;
  risk: "Low" | "Medium" | "High";
  scope: string;
  expires: string;
  status?: "pending" | "approved";
  class?: string;
}

const { summary, action, risk, scope, expires, status = "pending", class: className } = Astro.props;

const riskColor = {
  Low: "var(--color-ok)",
  Medium: "var(--color-beacon)",
  High: "var(--color-risk)",
}[risk];
---

<div class:list={["rounded-2xl border border-hairline bg-surface p-4 shadow-sm", className]}>
  <div class="flex items-start justify-between gap-3">
    <p class="text-[0.85rem] leading-snug font-semibold">{summary}</p>
    <span class="flex flex-none items-center gap-1.5 text-[0.68rem] font-semibold text-muted">
      <span class="status-dot" style={`background:${riskColor}`} aria-hidden="true"></span>
      {risk} risk
    </span>
  </div>

  <dl class="mt-3 space-y-1.5 text-[0.72rem]">
    <div class="flex justify-between gap-3">
      <dt class="text-muted">Action</dt>
      <dd class="text-right font-medium">{action}</dd>
    </div>
    <div class="flex justify-between gap-3">
      <dt class="text-muted">Scope</dt>
      <dd class="text-right font-medium">{scope}</dd>
    </div>
    <div class="flex justify-between gap-3">
      <dt class="text-muted">Expires</dt>
      <dd class="text-right font-medium">{expires}</dd>
    </div>
  </dl>

  {
    status === "pending" ? (
      <div class="mt-4 grid grid-cols-3 gap-2 text-center text-[0.75rem] font-semibold">
        <span class="rounded-full bg-ink px-2 py-1.5 text-white">Approve</span>
        <span class="rounded-full border border-hairline px-2 py-1.5 text-ink">Modify</span>
        <span class="rounded-full border border-hairline px-2 py-1.5 text-muted">Deny</span>
      </div>
    ) : (
      <p class="mt-4 flex items-center gap-2 rounded-full bg-ok-soft px-3 py-1.5 text-[0.75rem] font-semibold text-ok-deep">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="m2.5 6.5 2.5 2.5 4.5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
        Approved · single-use clearance issued
      </p>
    )
  }
</div>
